# Astro Fleet — Infrastructure Environment Variables
#
# SETUP:
# 1. Copy this file to .env
# 2. Fill in the values for your deployment
# 3. Run: docker-compose up -d
#
# SECURITY WARNING:
# - Change all default values before deploying to production
# - Use strong, random passwords for PostgreSQL
# - Never commit .env to version control (it's in .gitignore)
# - Rotate secrets periodically

# ============================================================================
# LET'S ENCRYPT — TLS Certificate Registration
# ============================================================================
# Email address used to register with Let's Encrypt.
# You'll receive certificate expiration reminders at this address.
# REQUIRED for automatic HTTPS.
ACME_EMAIL=admin@example.com

# ============================================================================
# POSTGRESQL — Database Credentials (optional, for future CMS integration)
# ============================================================================
# Only needed if you plan to integrate a headless CMS like Payload.
# For Astro Fleet v1 (static-only), these can remain unchanged.

# PostgreSQL username (default: "fleet")
POSTGRES_USER=fleet

# PostgreSQL password — CHANGE THIS TO A RANDOM STRING BEFORE PRODUCTION
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_to_a_random_string

# PostgreSQL database name (default: "fleet")
POSTGRES_DB=fleet

# ============================================================================
# TRAEFIK DASHBOARD — Optional (for monitoring)
# ============================================================================
# Uncomment below to enable Traefik dashboard at https://traefik.yourdomain.com
# (Requires adding a DNS record for traefik.yourdomain.com)
#
# Basic auth credentials can be generated with:
# echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
# Then set TRAEFIK_DASHBOARD_USER and TRAEFIK_DASHBOARD_PASSWORD below

# TRAEFIK_DASHBOARD_USER=admin
# TRAEFIK_DASHBOARD_PASSWORD=change_me_to_a_bcrypt_hash
