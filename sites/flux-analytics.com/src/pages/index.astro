---
import BaseLayout from '@astro-fleet/shared-ui/src/layouts/BaseLayout.astro';
import ServiceCard from '@astro-fleet/shared-ui/src/components/ServiceCard.astro';
import CTABlock from '@astro-fleet/shared-ui/src/components/CTABlock.astro';
import Banner from '@astro-fleet/shared-ui/src/components/Banner.astro';
import LogoCloud from '@astro-fleet/shared-ui/src/components/LogoCloud.astro';
import PricingTable from '@astro-fleet/shared-ui/src/components/PricingTable.astro';
import Newsletter from '@astro-fleet/shared-ui/src/components/Newsletter.astro';
import { SAAS } from '@astro-fleet/config/tokens';
import {
  SITE_NAME, TAGLINE, LOGO_SRC,
  navigation, footerColumns, contactInfo, socialLinks,
} from '../lib/site-config';

const logos = [
  { name: 'Linear' },
  { name: 'Retool' },
  { name: 'Vercel' },
  { name: 'Supabase' },
  { name: 'Railway' },
  { name: 'Tailscale' },
];

const pricingTiers = [
  {
    name: 'Hobby',
    price: '$0',
    period: 'mo',
    description: '50M events · 10k MTUs',
    features: [
      { text: 'Unlimited seats', included: true },
      { text: 'SQL workbench', included: true },
      { text: 'Warehouse sync', included: true },
      { text: 'Session Replay', included: false },
      { text: 'SSO / SAML', included: false },
      { text: 'Audit logs', included: false },
    ],
    ctaText: 'Start free',
    ctaHref: '/contact/',
  },
  {
    name: 'Team',
    price: '$99',
    period: 'mo',
    description: '1B events · 100k MTUs',
    features: [
      { text: 'Unlimited seats', included: true },
      { text: 'SQL workbench', included: true },
      { text: 'Warehouse sync', included: true },
      { text: 'Session Replay', included: true },
      { text: 'SSO / SAML', included: false },
      { text: 'Audit logs', included: false },
    ],
    ctaText: 'Start free',
    ctaHref: '/contact/',
    highlighted: true,
    badge: 'Most popular',
  },
  {
    name: 'Scale',
    price: 'Custom',
    description: 'SSO · Audit logs · DPA',
    features: [
      { text: 'Unlimited seats', included: true },
      { text: 'SQL workbench', included: true },
      { text: 'Warehouse sync', included: true },
      { text: 'Session Replay', included: true },
      { text: 'SSO / SAML', included: true },
      { text: 'Audit logs', included: true },
    ],
    ctaText: 'Contact sales',
    ctaHref: '/contact/',
  },
];

const features = [
  {
    title: 'Event pipeline',
    description: 'Stream billions of product events a day through a warehouse-native pipeline. Schema-enforced, zero data loss, and typed SDKs for every language.',
    href: '/services/',
    linkText: 'Read the docs',
  },
  {
    title: 'Funnels & cohorts',
    description: 'Build retention cohorts and conversion funnels in seconds. No PRs, no pipeline changes — your PM and your staff engineer work from the same numbers.',
    href: '/services/',
    linkText: 'See funnels',
  },
  {
    title: 'SQL workbench',
    description: 'Drop into SQL when the UI runs out. Query raw events with a notebook-style editor, share results as dashboards, and alert on thresholds.',
    href: '/services/',
    linkText: 'Open workbench',
  },
];
---

<BaseLayout
  title={`${SITE_NAME} — Product analytics for engineering teams`}
  description="Flux is a warehouse-native product analytics platform built for teams who ship fast. Event pipeline, funnels, session replay, and SQL in one tool."
  keywords={['product analytics','saas','developer tools','event tracking','funnels']}
  {navigation}
  footerColumns={footerColumns}
  {contactInfo}
  {socialLinks}
  siteName={SITE_NAME}
  tagline={TAGLINE}
  logoSrc={LOGO_SRC}
  ctaText="Start free"
  ctaHref="/contact/"
  designTokens={SAAS}
>
  <Banner
    text="Session Replay is now GA — try it free."
    linkText="Learn more"
    linkHref="/services/"
    variant="accent"
    dismissible={true}
    id="banner-session-replay"
  />

  <!-- Hero with code mockup -->
  <section class="f-hero">
    <div class="f-hero__grid">
      <div class="f-hero__copy">
        <a href="/about/" class="f-hero__pill">
          <span class="f-hero__pill-new">New</span>
          Session Replay is out of beta →
        </a>
        <h1 class="f-hero__title">
          Product analytics<br/>
          <span class="f-hero__title--grad">shipped by engineers.</span>
        </h1>
        <p class="f-hero__lede">
          Event pipeline, funnels, cohorts, and session replay — all running on
          your own warehouse. Install in four lines, query in SQL, no sampling.
        </p>
        <div class="f-hero__actions">
          <a href="/contact/" class="f-btn f-btn--primary">Start free →</a>
          <a href="/services/" class="f-btn f-btn--ghost">$ npm i @flux/sdk</a>
        </div>
        <div class="f-hero__meta">
          <span class="f-dot"></span> No credit card · 50M events free tier · SOC 2 Type II
        </div>
      </div>

      <div class="f-code" aria-hidden="true">
        <div class="f-code__chrome">
          <span></span><span></span><span></span>
          <div class="f-code__file">app/checkout.ts</div>
        </div>
        <pre class="f-code__body"><code><span class="t-kw">import</span> <span class="t-var">&#123; flux &#125;</span> <span class="t-kw">from</span> <span class="t-str">'@flux/sdk'</span>;

<span class="t-com">// ⚡ Type-safe, autocompleted events</span>
<span class="t-fn">flux.track</span>(<span class="t-str">'checkout_completed'</span>, &#123;
  <span class="t-var">user_id</span>: user.id,
  <span class="t-var">amount</span>: <span class="t-num">129.00</span>,
  <span class="t-var">currency</span>: <span class="t-str">'USD'</span>,
  <span class="t-var">plan</span>: <span class="t-str">'team_annual'</span>,
&#125;);

<span class="t-com">// → streamed to your warehouse in &lt; 2s</span></code></pre>
      </div>
    </div>
  </section>

  <!-- Logo strip -->
  <LogoCloud
    logos={logos}
    heading="Trusted by engineering teams at"
  />

  <!-- Features -->
  <section class="section">
    <div class="container">
      <div class="f-section-head">
        <div class="f-eyebrow">Built for the stack you already run</div>
        <h2>Everything a staff engineer would build in-house.<br/><span>Without spending six months building it.</span></h2>
      </div>
      <div class="f-features">
        {features.map((f) => (
          <ServiceCard title={f.title} description={f.description} href={f.href} linkText={f.linkText} />
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <PricingTable
    tiers={pricingTiers}
    heading="Starts free. Scales with your MRR."
    description="Every plan includes unlimited seats, SQL workbench, and warehouse sync. We bill on monthly tracked users — so you can fire as many events as you like."
  />

  <Newsletter
    heading="The Flux Engineering Blog"
    description="Deep dives on event pipelines, query optimization, and building developer tools. No spam."
    buttonText="Subscribe"
    placeholder="you@company.com"
    variant="filled"
  />

  <CTABlock
    heading="Install in four lines. Ship today."
    description="Start free, keep your data in your warehouse, and never argue about numbers in a standup again."
    primaryButton={{ text: 'Start free', href: '/contact/' }}
    secondaryButton={{ text: 'Read the docs', href: '/services/' }}
  />
</BaseLayout>

<style>
  :root {
    --f-grid-line: rgba(52, 211, 153, 0.06);
  }
  /* Hero */
  .f-hero {
    position: relative;
    padding: 5rem 1.5rem 5rem;
    background:
      radial-gradient(ellipse at top right, rgba(16,185,129,0.14), transparent 55%),
      linear-gradient(180deg, #0d1117 0%, #0a0f14 100%);
    overflow: hidden;
  }
  .f-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(var(--f-grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--f-grid-line) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }
  .f-hero__grid {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 960px) { .f-hero__grid { grid-template-columns: 1.1fr 1fr; gap: 3.5rem; } }
  .f-hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.375rem 0.875rem 0.375rem 0.375rem;
    background: rgba(16,185,129,0.08);
    border: 1px solid rgba(16,185,129,0.2);
    border-radius: 999px;
    color: #e6edf3;
    font-size: 0.8125rem;
    text-decoration: none;
    margin-bottom: 2rem;
  }
  .f-hero__pill-new {
    padding: 0.1875rem 0.5rem;
    background: var(--color-accent, #34d399);
    color: #0a0f14;
    font-weight: 700;
    font-size: 0.6875rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .f-hero__title {
    font-family: var(--font-heading, 'Sora', sans-serif);
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.5rem;
  }
  .f-hero__title--grad {
    background: linear-gradient(135deg, #34d399 0%, #60a5fa 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .f-hero__lede {
    font-size: 1.1875rem;
    line-height: 1.65;
    color: #8b949e;
    max-width: 540px;
    margin-bottom: 2rem;
  }
  .f-hero__actions { display: flex; flex-wrap: wrap; gap: 0.875rem; margin-bottom: 1.5rem; }
  .f-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.8125rem 1.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.625rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .f-btn--primary {
    background: linear-gradient(180deg, #34d399 0%, #10b981 100%);
    color: #0a0f14;
    box-shadow: 0 8px 32px -8px rgba(16,185,129,0.5);
  }
  .f-btn--primary:hover { transform: translateY(-1px); opacity: 1; }
  .f-btn--ghost {
    background: rgba(255,255,255,0.03);
    border: 1px solid #30363d;
    color: #e6edf3;
    font-family: 'SFMono-Regular', Menlo, Consolas, monospace;
    font-size: 0.875rem;
  }
  .f-btn--ghost:hover { border-color: #34d399; color: #34d399; opacity: 1; }
  .f-hero__meta { font-size: 0.8125rem; color: #6e7681; }
  .f-dot {
    display: inline-block; width: 8px; height: 8px;
    background: #34d399; border-radius: 50%;
    margin-right: 0.5rem;
    box-shadow: 0 0 0 3px rgba(52,211,153,0.18);
  }

  /* Code mockup */
  .f-code {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 30px 80px -20px rgba(0,0,0,0.5), 0 0 0 1px rgba(52,211,153,0.08);
  }
  .f-code__chrome {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.75rem 1rem;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }
  .f-code__chrome span {
    width: 12px; height: 12px; border-radius: 50%; background: #30363d;
  }
  .f-code__chrome span:nth-child(1) { background: #ff5f57; }
  .f-code__chrome span:nth-child(2) { background: #febc2e; }
  .f-code__chrome span:nth-child(3) { background: #28c840; }
  .f-code__file {
    margin-left: auto;
    font-family: 'SFMono-Regular', Menlo, monospace;
    font-size: 0.75rem;
    color: #8b949e;
  }
  .f-code__body {
    margin: 0;
    padding: 1.5rem;
    font-family: 'SFMono-Regular', Menlo, Consolas, monospace;
    font-size: 0.8125rem;
    line-height: 1.7;
    color: #e6edf3;
    overflow-x: auto;
  }
  .t-kw  { color: #ff7b72; }
  .t-str { color: #a5d6ff; }
  .t-num { color: #79c0ff; }
  .t-fn  { color: #d2a8ff; }
  .t-var { color: #ffa657; }
  .t-com { color: #8b949e; font-style: italic; }

  /* Section head + features */
  .f-section-head { max-width: 720px; margin-bottom: 3rem; }
  .f-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent, #34d399);
    margin-bottom: 0.875rem;
  }
  .f-section-head h2 {
    font-family: var(--font-heading, 'Sora', sans-serif);
    font-size: clamp(1.875rem, 4.5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: #e6edf3;
  }
  .f-section-head h2 span { color: #8b949e; font-weight: 700; }

  .f-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) { .f-features { grid-template-columns: repeat(3, 1fr); } }

</style>
